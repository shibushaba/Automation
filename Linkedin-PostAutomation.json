      "parameters": {
        "jsCode": "const b64 = '';\n\nfor (const item of $input.all()) {\n  item.binary = item.binary || {};\n  item.binary.template = {\n    data: b64,\n    mimeType: 'image/png',\n    fileName: 'template.png'\n  };\n}\n\nreturn $input.all();"
      },
