      "parameters": {
        "jsCode": "const dbItems = $input.all();\nlet name = 'missing';\nlet email = 'missing';\nlet phone = 'missing';\nlet requirement = 'missing';\nlet aiInput = '';\nlet senderId = '';\n\nif (dbItems.length > 0 && dbItems[0].json) {\n  const data = dbItems[0].json;\n  name = data.NAME || 'missing';\n  email = data.EMAIL || 'missing';\n  phone = data.PHONE || 'missing';\n  requirement = data.REQUIRMENT || data.REQUIREMENT || 'missing';\n  aiInput = data.aiInput || '';\n  senderId = data.senderId || '';\n}\n\nconst memoryFlag = `Known lead info:\nName: ${name}\nEmail: ${email}\nPhone: ${phone}\nRequirement: ${requirement}`;\n\nif (!aiInput || !senderId) {\n    const webhookNode = $items().find(i => i.json && i.json.body && i.json.body.entry);\n    if (webhookNode) {\n        const webhookData = webhookNode.json.body.entry[0];\n        if (webhookData.messaging && webhookData.messaging.length > 0) {\n            aiInput = webhookData.messaging[0].message.text;\n            senderId = webhookData.messaging[0].sender.id;\n        } else if (webhookData.changes && webhookData.changes.length > 0) {\n            aiInput = webhookData.changes[0].value.text;\n            senderId = (webhookData.changes[0].value.from ? webhookData.changes[0].value.from.id : webhookData.changes[0].value.id) || '';\n        }\n    }\n}\n\nreturn {\n  json: {\n    aiInput: aiInput || '',\n    senderId: senderId || '',\n    memoryContext: memoryFlag\n  }\n};"
      },
