        "jsCode": "const rawMsg = $input.item.json.aiInput || '';\nconst bikeIdMatch = rawMsg.match(/\\bBK-\\d+\\b/i);\n\nif (bikeIdMatch) {\n  return [{ action: 'search_db', action_param: bikeIdMatch[0].toUpperCase(), reply_to_user: 'Searching...' }];\n}\n\nreturn [{ action: 'none', action_param: '', reply_to_user: 'Hey , veetile vandi here..... hope your doing well😊\\n\\n1. Bike nte details aryan \"BIKE ID\" ayakkuka (eg: bk-2)\\n\\n2. Bike request cheyyan njangalude website il kayari \"REQUEST BIKE\" option upayokikkam (we prioritize people requested before uploading video)\\n\\n3. our website : \"most-affordable.vercel.app\"\\n\\nThanks for choosing us🫂' }];"
